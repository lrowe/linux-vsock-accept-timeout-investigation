{
  "boot-source": {
    "kernel_image_path": "../linux/vmlinux",
    "boot_args": "console=ttyS0 reboot=k panic=1 -- /bin/httpserver vsock:3:8000",
    "initrd_path": "target/initrd.cpio"
  },
  "drives": [],
  "machine-config": {
    "vcpu_count": 1,
    "mem_size_mib": 256
  },
  "vsock": {
    "guest_cid": 3,
    "uds_path": "target/v.sock"
  }
}
